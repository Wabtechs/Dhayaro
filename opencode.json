{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "build": {
      "steps": 50
    },
    "plan": {
      "mode": "primary"
    }
  },
  "permission": {
    "bash": {
      "npm *": "allow",
      "npx *": "allow",
      "git *": "allow",
      "python *": "allow",
      "pip *": "allow",
      "pytest *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "external_directory": {
      "backend/**": "allow",
      "src/**": "allow",
      "*.json": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.py": "allow",
      "*.css": "allow",
      "*.md": "allow"
    }
  },
  "tool_output": {
    "max_lines": 300,
    "max_bytes": 65536
  }
}
